# ============================================================
# Phosphor Studio — .gitignore
#
# 原则:
#   1. 敏感信息绝对不入库(API Key / 数据库密码 / 加密密钥)
#   2. 构建产物不入库(.next / dist / *.tsbuildinfo)
#   3. 用户生成的数据不入库(library/ 里的媒体 + manifest)
#   4. 开发工具个人配置不入库(.zcode/ .vscode/ .idea/ 等)
#   5. 操作系统临时文件不入库(.DS_Store / Thumbs.db 等)
# ============================================================


# ---------- 敏感信息(绝对不入库) ----------
# 任何含真实密钥/密码/凭证的文件
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account*.json
.env.production
.env.staging


# ---------- 依赖 ----------
/node_modules/
/.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions


# ---------- 构建产物 ----------
/.next/
/out/
/build/
/dist/
*.tsbuildinfo
next-env.d.ts


# ---------- 测试产物 ----------
/coverage/
*.lcov
.nyc_output/


# ---------- 本地数据(用户生成的作品库) ----------
# gallery/归档/缓存下载的图片视频,按项目隔离,不入库
/library/


# ---------- Prisma(multi-user 分支) ----------
# 生成的 Prisma Client 不入库(由 postinstall: prisma generate 重建)
# 迁移文件要入库(团队共享 schema 演进)
/prisma/migrations/dev/


# ---------- AI 编码助手 / IDE 配置(个人开发环境) ----------
# 这些是开发工具的个人配置,不属于项目源码,每人不同,入库只会冲突
.zcode/
.vscode/
.idea/
.cursor/
.aider*
.claude/
CLAUDE.md
AGENTS.md
.continue/
.codeium/


# ---------- 操作系统文件 ----------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
# Linux
*~
.directory
.Trash-*


# ---------- 日志 ----------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# ---------- 部署 ----------
.vercel
.idea/


# ---------- 其他临时文件 ----------
*.tmp
*.bak
*.swp
*.swo
.cache/
.turbo/
