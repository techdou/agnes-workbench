# ============================================================
# Phosphor Studio — .gitignore
# 原则:敏感信息不入库、构建产物不入库、开发工具配置不入库
# ============================================================

# ---------- 敏感信息(绝对不入库) ----------
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
service-account*.json

# ---------- 依赖 ----------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------- 构建产物 ----------
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# ---------- 本地数据(用户生成的作品库) ----------
/library

# ---------- 测试 ----------
/coverage

# ---------- AI 编码助手 / IDE 配置(个人开发环境,不入库) ----------
# 这些是开发工具的个人配置,不属于项目源码
.zcode/
.vscode/
.idea/
.cursor/
.aider*
.claude/
CLAUDE.md
AGENTS.md
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------- 操作系统文件 ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------- 日志 ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# ---------- 部署 ----------
.vercel
