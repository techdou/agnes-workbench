# ============================================================
# Phosphor Studio — 环境变量
# 复制此文件为 .env.local 并填入真实值
# ============================================================

# ---------- 数据库(PostgreSQL) ----------
# 本地:postgresql://用户名:密码@localhost:5432/phosphor
# 云端:Neon / Supabase / RDS 等提供的连接串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/phosphor"

# ---------- Auth.js v5 ----------
# 生成:openssl rand -base64 32
AUTH_SECRET=""

# ---------- API Key 加密密钥(用户 Agnes Key 加密用) ----------
# 生成:openssl rand -base64 32(必须是 base64 编码的 32 字节)
ENCRYPTION_KEY=""

# ---------- 首个管理员邮箱 ----------
# 注册时邮箱匹配此值,自动授予 ADMIN 角色
ADMIN_EMAIL="admin@example.com"

# ---------- Agnes AI API 配置(可选,作为用户未填 Key 时的 fallback) ----------
# 申请地址:https://platform.agnes-ai.com → API Keys → Create new secret key
AGNES_API_KEY=sk-your-api-key-here

# API 网关地址(默认即可,一般不用改)
AGNES_BASE_URL=https://apihub.agnes-ai.com
