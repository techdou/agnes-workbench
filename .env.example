# ============================================================
# Phosphor Studio — 环境变量示例
#
# 用法: cp .env.example .env.local,把下面的占位符换成你的真实值
# ============================================================


# ---------- Agnes AI API(main + multi-user 都需要) ----------
# 申请地址: https://platform.agnes-ai.com → API Keys → Create new secret key
# 留空时,用户可在设置面板填自己的 Key(优先级高于此环境变量)
AGNES_API_KEY=sk-your-api-key-here

# API 网关地址(默认即可,一般不用改)
AGNES_BASE_URL=https://apihub.agnes-ai.com

# 可选: 缓存代理 SSRF 白名单(逗号分隔的域名后缀,扩充 Agnes 新域名时用)
# 不配则用默认: agnes-ai.com,agnesai.com
# AGNES_SSRF_ALLOW_SUFFIXES=agnes-ai.com,agnesai.com


# ============================================================
# 以下变量仅 feat/multi-user 分支需要(main 分支单机版用不到)
# main 分支用 IndexedDB 本地存储,无需数据库和鉴权
# ============================================================

# ---------- 数据库(PostgreSQL) ----------
# 本地开发: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
# 生产: 用 Vercel Postgres / Supabase / Neon 等
# DATABASE_URL="postgresql://user:password@localhost:5432/phosphor"

# ---------- Auth.js v5(会话鉴权) ----------
# 生成: openssl rand -base64 32
# AUTH_SECRET="generate-with-openssl-rand-base64-32"

# ---------- API Key 加密密钥(用户 Agnes Key 的 AES-256-GCM 加密) ----------
# 生成: openssl rand -base64 32
# 用户在设置面板填的 API Key 会用这个密钥加密后存数据库,不明文落库
# ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# ---------- 首个管理员邮箱(可选) ----------
# 注册时邮箱匹配此值会自动授予 ADMIN 角色(管理后台访问权)
# ADMIN_EMAIL="your-admin@example.com"
